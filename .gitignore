# ─── Secrets ────────────────────────────────────────────────────────────
.env

# ─── Python virtual environment ─────────────────────────────────────────
.venv/
# If you ever use Poetry:
# .venv  (Poetry might create it without the leading dot)

# ─── Byte-code / cache ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ─── Editor settings (optional) ─────────────────────────────────────────
.vscode/

# ─── Build & packaging artefacts ────────────────────────────────────────
dist/
build/
*.egg-info/

# ─── Data & outputs you don’t want in Git ───────────────────────────────
downloads/
data/
logs/

# ─── OS / OneDrive cruft ────────────────────────────────────────────────
.DS_Store
Thumbs.db
~$*

# ─── Auto-generated ILINet & report files ───────────────────────────────
outputs/

# ─── Playwright browser binaries (installed at runtime) ─────────────────
playwright/.local-browsers/

# ─── Test / coverage caches (if you use pytest, coverage, mypy) ─────────
.pytest_cache/
.coverage
.mypy_cache/

# ─── Jupyter & VS Code notebooks / checkpoints (optional) ───────────────
.ipynb_checkpoints/

# ─── JetBrains IDE config (optional) ────────────────────────────────────
.idea/